<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/history_item_card"
    style="@style/Widget.Material3.CardView.Filled"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardElevation="0dp"
    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Large"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="top"
        android:orientation="horizontal"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="72dp"
            android:layout_gravity="center_vertical"
            app:cardElevation="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.BiliTools.Cover"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/history_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/history_cover_desc"
                android:scaleType="centerCrop"
                tools:src="@drawable/empty" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/history_cover_progress"
                style="@style/Widget.BiliTools.DownloadProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:translationY="1dp"
                android:visibility="gone"
                app:trackColor="?attr/colorSurfaceContainerHighest"
                tools:progress="45"
                tools:visibility="visible" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="top|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/history_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textAppearance="@style/TextAppearance.BiliTools.History.ItemTitle"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="Sample history title" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/history_download"
                    style="@style/Widget.Material3Expressive.Button.IconButton.Standard"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/history_download"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="8dp"
                    android:tooltipText="@string/history_download"
                    app:icon="@drawable/ic_save_alt_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="?attr/colorPrimary"
                    tools:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/history_view_at"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.BiliTools.History.Meta"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="2026-02-03 20:15" />

            <TextView
                android:id="@+id/history_progress_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textAppearance="@style/TextAppearance.BiliTools.History.Meta"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="03:12 / 12:40" />

            <LinearLayout
                android:id="@+id/history_author_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/history_author_avatar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    tools:src="@drawable/default_avatar" />

                <TextView
                    android:id="@+id/history_author"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.BiliTools.History.Author"
                    android:textColor="?attr/colorPrimary"
                    tools:text="Author" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
